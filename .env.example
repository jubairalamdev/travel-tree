# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-min-32-chars
BETTER_AUTH_URL=https://your-frontend.vercel.app

# MongoDB Connection (for Better Auth sessions)
MONGO_DB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/travel-tree?retryWrites=true&w=majority

# Demo Login Credentials
NEXT_PUBLIC_DEMO_EMAIL=demo@example.com
NEXT_PUBLIC_DEMO_PASSWORD=DemoPassword123

# Backend API (your Express backend production URL)
NEXT_PUBLIC_API_URL=https://your-backend.vercel.app/api

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
